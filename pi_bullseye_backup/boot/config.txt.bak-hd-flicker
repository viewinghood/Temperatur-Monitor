# TempMonitor — Bullseye LITE stable boot. hdmi_safe 640x480. NO KMS. NO DSI lines.
disable_overscan=0
hdmi_force_hotplug=1
hdmi_drive=2
hdmi_group=2
hdmi_mode=35
#hdmi_safe=1  # disabled for HD

dtparam=i2c_arm=on
dtparam=spi=on
dtparam=audio=on
enable_uart=1
dtoverlay=pi3-miniuart-bt

start_x=0
gpu_mem=128
camera_auto_detect=0
display_auto_detect=0

# NO ignore_lcd / lcd_rotate — caused flicker on Lite

[all]
